datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER
  ADMIN
  HOST
}

enum TaxAppliesTo {
  NIGHTLY
  CLEANING
  SERVICE
  ALL
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phoneNumber   String?   @unique
  emailVerified DateTime?
  image         String?
  hashedPassword String?
  role          UserRole  @default(USER)
  status        String    @default("ACTIVE")
  deactivatedAt DateTime?
  deletedAt     DateTime?
  deletedById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  favoriteIds   String[]

  accounts      Account[]
  sessions      Session[]
  listings      Listing[]
  reservations  Reservation[]
  lodgifyBookingSessions LodgifyBookingSession[]
  reviews       Review[]
  adminAuditLogs AdminAuditLog[] @relation("AdminAuditLogs")
  cancellationRequests CancellationRequest[]
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  targetType String?
  metadata  Json?
  createdAt DateTime @default(now())

  admin     User     @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Listing {
  id                    String   @id @default(cuid())
  title                 String
  description           String
  imageSrc              String
  displayOrder          Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  category              String
  roomCount             Int
  bathroomCount         Int
  guestCount            Int
  locationValue         String
  userId                String
  price                 Int
  amenities             Json[]   @default([])
  rules                 String[]
  sleepingArrangements  String[]
  mapIframe             String?  @db.Text
  
  // New dynamic fields for highlights
  highlights            Json[]  @default([])
  
  // Features and details
  features              Json[]    @default([])
  
  // House rules
  houseRules            String[]  @default([])
  
  // Cancellation policy
  cancellationPolicy    String?   @db.Text
  
  // Check-in/Check-out info
  checkInTime           String?   @default("3:00 PM")
  checkOutTime          String?   @default("11:00 AM")
  
  // About the host
  hostDescription       String?   @db.Text
  
  // Pricing details
  basePricePerNight     Int?
  cleaningFee           Int?
  serviceFee            Int?
  petFee                Int?
  taxPercentage         Float?    @default(10)
  taxProfileId          String?
  
  // Availability and minimum stay
  minStayNights         Int?      @default(1)
  dynamicPricingRules   Json[]    @default([])
  maxGuestsAllowed      Int?
  
  // Instant book
  instantBook           Boolean   @default(false)

  // Marks listing as not yet open for booking/details
  comingSoon            Boolean   @default(false)
  
  // Visibility
  isActive              Boolean   @default(true)
  
  // Subtitle
  subtitle              String?
  lodgifyPropertyId     String?
  lodgifyRoomTypeId     String?
  lodgifyBookingUrl     String?
  lodgifyWidgetEmbed    String?   @db.Text

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations          Reservation[]
  lodgifyBookingSessions LodgifyBookingSession[]
  reviews               Review[]
  images                ListingImage[]
  specifications        ListingSpecification[]
  advantages            ListingAdvantage[]
  bedrooms              ListingBedroom[]
  gallerySections       ListingGallerySection[]
  taxProfile            TaxProfile? @relation(fields: [taxProfileId], references: [id], onDelete: SetNull)
}

model LodgifyBookingSession {
  id                   String   @id @default(cuid())
  token                String   @unique
  userId               String
  listingId            String
  lodgifyPropertyId    String?
  lodgifyReservationId String?  @unique
  guestEmail           String?
  redirectPath         String?
  createdAt            DateTime @default(now())
  expiresAt            DateTime
  claimedAt            DateTime?

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing              Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([listingId, createdAt])
  @@index([lodgifyPropertyId, createdAt])
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  imageUrl  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingSpecification {
  id          String   @id @default(cuid())
  listingId   String
  title       String
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingAdvantage {
  id          String   @id @default(cuid())
  listingId   String
  title       String
  description String
  iconUrl     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingBedroom {
  id          String   @id @default(cuid())
  listingId   String
  name        String
  type        String
  description String
  imageUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingGallerySection {
  id        String   @id @default(cuid())
  listingId String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  images    ListingGalleryImage[]
}

model ListingGalleryImage {
  id         String   @id @default(cuid())
  sectionId  String
  imageUrl   String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  section    ListingGallerySection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model Reservation {
  id         String   @id @default(cuid())
  userId     String
  listingId  String
  startDate  DateTime
  endDate    DateTime
  nights     Int      @default(1)
  adults     Int      @default(1)
  children   Int      @default(0)
  infants    Int      @default(0)
  pets       Int      @default(0)
  pricePerNight Int
  subtotal   Int
  cleaningFee Int    @default(0)
  serviceFee Int     @default(0)
  taxPercentage Float @default(0)
  taxAmount  Int     @default(0)
  taxBreakdown Json? @default("[]")
  totalPrice Int
  stripeSessionId String? @unique
  stripePaymentIntentId String?
  stripeChargeId String?
  stripeBalanceTransactionId String?
  bookingSource String @default("direct")
  primaryGuestName String?
  primaryGuestEmail String?
  primaryGuestPhone String?
  primaryGuestLocale String?
  primaryGuestStreetAddress1 String?
  primaryGuestStreetAddress2 String?
  primaryGuestCity String?
  primaryGuestState String?
  primaryGuestPostalCode String?
  primaryGuestCountryCode String?
  agreementPolicyId String?
  agreementPolicyVersion Int?
  agreementPolicyTitle String?
  agreementAcceptedAt DateTime?
  paymentPolicyId String?
  paymentPolicyVersion Int?
  paymentPolicyTitle String?
  paymentPolicyAcceptedAt DateTime?
  lodgifyPropertyId String?
  lodgifyRoomTypeId String?
  lodgifyReservationId String? @unique
  lodgifySyncStatus String @default("pending")
  lodgifySyncError String? @db.Text
  lodgifySyncedAt DateTime?
  paymentStatus String? @default("unpaid")
  paymentCurrency String? @default("usd")
  amountPaid Int? @default(0)
  cardBrand String?
  cardLast4 String?
  cardExpMonth Int?
  cardExpYear Int?
  refundStatus String? @default("none")
  refundedAmount Int? @default(0)
  stripeRefundIds String[] @default([])
  refundHistory Json[] @default([])
  // Deposit / balance-due fields (policy: 50% at booking, balance 60 days before arrival)
  paymentType  String  @default("full")         // "full" | "deposit"
  depositAmount Int?                             // cents charged at booking (50% when deposit)
  balanceDueAmount Int?                          // cents remaining (0 when full payment)
  balanceDueDate DateTime?                       // 60 days before arrival
  balancePaid Boolean @default(false)
  balancePaidAt DateTime?
  balanceStripePaymentIntentId String?
  stripeCustomerId String?                       // Stripe customer for off-session balance charge
  stripePaymentMethodId String?                  // saved card for balance charge
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  cancellationRequests CancellationRequest[]
}

model TaxProfile {
  id            String   @id @default(cuid())
  name          String
  country       String   @default("US")
  state         String?
  county        String?
  city          String?
  isActive      Boolean  @default(true)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  vatRate       Float    @default(0)
  gstRate       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines         TaxProfileLine[]
  listings      Listing[]
}

model PolicyDocument {
  id        String   @id @default(cuid())
  policyKey String
  title     String
  content   String   @db.Text
  version   Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([policyKey, version])
  @@index([policyKey, isActive])
}

model TaxProfileLine {
  id          String       @id @default(cuid())
  taxProfileId String
  label       String
  rate        Float
  appliesTo   TaxAppliesTo @default(ALL)
  order       Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  taxProfile  TaxProfile   @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model CancellationRequest {
  id                   String    @id @default(cuid())
  // For local DB reservations
  reservationId        String?
  // For Lodgify-only reservations not stored locally
  lodgifyReservationId String?
  userId               String
  listingTitle         String
  startDate            DateTime
  endDate              DateTime
  reason               String?   @db.Text
  // "pending" | "approved" | "rejected"
  status               String    @default("pending")
  adminNote            String?   @db.Text
  createdAt            DateTime  @default(now())
  processedAt          DateTime?

  reservation          Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}
